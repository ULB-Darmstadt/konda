# Copy to ".env" and fill in values.

# App
BACKEND_PORT=5050

# Azure OpenAI (used by this app for chat-based steps)
# Fill these in to enable AI steps.
AOAI_CHAT_COMPLETIONS_API_KEY="<YOUR_AZURE_OPENAI_API_KEY>"
AOAI_CHAT_COMPLETIONS_ENDPOINT="https://<YOUR_RESOURCE_NAME>.openai.azure.com"
AOAI_CHAT_COMPLETIONS_MODEL="<YOUR_CHAT_DEPLOYMENT_NAME>"
AOAI_SYSTEM_MESSAGE="You are a research assistant who is very good at creating metadata from file sets and papers and transform this metadata into knowledge graphs."
# Neo4j GenAI plugin settings (used by Neo4j procedures like genai.vector.encodeBatch).
NEO4J_GENAI_RESOURCE="<YOUR_AZURE_OPENAI_RESOURCE_NAME>"
NEO4J_GENAI_EMBEDDING_DEPLOYMENT="<YOUR_EMBEDDING_DEPLOYMENT_NAME>"

# Neo4j connection (Bolt/driver)
NEO4J_DB_URL="neo4j://localhost:7687"
NEO4J_USERNAME="<YOUR_USERNAME>"
NEO4J_PASSWORD="<YOUR_PASSWORD>"

# Neo4j HTTP endpoint (used for RDF export endpoints in this app)
NEO4J_HTTP_URL="http://localhost:7474"
